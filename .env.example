# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Channel ID (e.g. -1001234567890) or username (e.g. @my_channel)
# The bot must be added to the channel as an administrator.
TELEGRAM_CHANNEL_ID=-1001234567890
